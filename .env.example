# ── App ──────────────────────────────────────────────────────────
APP_NAME=Friends
DEBUG=false
TIMEZONE=America/Sao_Paulo

# ── Database ─────────────────────────────────────────────────────
# SQLite local-first (default da v1)
DATABASE_URL=sqlite+aiosqlite:///./friends.db

# ── Frontend CORS ────────────────────────────────────────────────
# Lista separada por virgula quando houver multiplas origens
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# ── Integracao Evernote via IFTTT ────────────────────────────────
# Obter em https://ifttt.com/maker_webhooks/settings
IFTTT_WEBHOOK_KEY=
# Nome do evento configurado no applet Webhooks -> Evernote Append to note
IFTTT_EVENT_NAME=friends_log

# ── Integracao Google Calendar ───────────────────────────────────
# Credenciais OAuth2 do projeto criado em console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# O refresh_token do usuario e gravado aqui apos o fluxo OAuth inicial.
# Este caminho deve ficar fora do repo.
GOOGLE_TOKEN_PATH=~/.friends/google_token.json
