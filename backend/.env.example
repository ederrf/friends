# Friends backend — configuracao de exemplo.
# Copie para `.env` e preencha com valores reais.
# .env e git-ignorado.

# ── App ──────────────────────────────────────────────────────────
APP_NAME="Friends"
DEBUG=false
TIMEZONE="America/Sao_Paulo"

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL="sqlite+aiosqlite:///./friends.db"

# ── Frontend (CORS) ──────────────────────────────────────────────
# Lista JSON de origens permitidas pelo middleware de CORS.
# CORS_ORIGINS='["http://localhost:5173","http://127.0.0.1:5173"]'

# ── Integracao Evernote via IFTTT (13.12) ────────────────────────
# Pegue a chave em https://ifttt.com/maker_webhooks/settings
# Applet sugerido: Webhooks (Receive a web request) -> Evernote (Append to note)
# value1 = titulo da nota (convencao: "Friends: {nome}")
# value2 = corpo a ser appendado
IFTTT_WEBHOOK_KEY=""
IFTTT_EVENT_NAME="friends_log"

# ── Integracao Google Calendar (13.13) ───────────────────────────
# Criado em https://console.cloud.google.com/ (OAuth 2.0 client).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Caminho onde o refresh_token e armazenado (fora do repo).
GOOGLE_TOKEN_PATH="~/.friends/google_token.json"
